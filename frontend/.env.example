# IgranSense Frontend Environment Configuration
# Copy this file to .env and update the values as needed

# Backend API URL
VITE_API_BASE_URL=http://localhost:8000

# App Configuration
VITE_APP_TITLE=IgranSense Dashboard
VITE_APP_VERSION=0.1.0

# Map Configuration (for future use)
# VITE_MAP_DEFAULT_CENTER_LAT=31.6369
# VITE_MAP_DEFAULT_CENTER_LON=-7.9896
# VITE_MAP_DEFAULT_ZOOM=13

# Feature Flags (for future use)
# VITE_FEATURE_ADMIN_PANEL=true
# VITE_FEATURE_MULTI_FARM=true

# Note: Vite only exposes variables prefixed with VITE_
# The current setup uses proxy configuration in vite.config.js
